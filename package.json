{
    "name": "n8n-nodes-telegram-better-markdown",
    "version": "1.0.0",
    "description": "n8n node to convert Markdown to Telegram-compatible HTML for use with Telegram Bot API",
    "license": "MIT",
    "homepage": "https://github.com/andresberrios/n8n-nodes-telegram-better-markdown",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "telegram",
        "markdown",
        "html",
        "bot",
        "telegram-bot",
        "formatting"
    ],
    "author": {
        "name": "Andres Berrios",
        "email": "andres.berrios.j@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/andresberrios/n8n-nodes-telegram-better-markdown.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "credentials": [],
        "nodes": [
            "dist/nodes/TelegramMarkdown/TelegramMarkdown.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "remark-parse": "^11.0.0",
        "unified": "^11.0.5"
    }
}
